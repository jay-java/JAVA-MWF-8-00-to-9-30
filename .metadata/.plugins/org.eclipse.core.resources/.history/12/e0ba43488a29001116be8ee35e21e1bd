package core;

public class P004_Operators {
	public static void main(String[] args) {
		// 1.Assignment -> =,+=,-=,*=,/=
		int a = 1;
		a += 12; // a = a+12
		System.out.println(a); // 13
		a -= 4; // a = a-4
		System.out.println(a); // 9
		a *= 2; // a = a*2
		System.out.println(a);
		a /= 2;
		System.out.println(a);
		// 2.Arithmetic -> +,-,*,/,%
		// 3.Conditional -> >,<,>=,<=,==,!=
		// 4.logical -> &&, || , !
		// 5.unary -> ++,--
	}
}
